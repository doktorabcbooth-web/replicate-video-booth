CLOUDINARY_API_SECRET=xxx
NEXT_PUBLIC_CLOUDINARY_LOGO_ID=logo_public_id

# Resend
RESEND_API_KEY=res_xxx
EMAIL_FROM=you@domain.com

# App url
APP_URL=http://localhost:3000
